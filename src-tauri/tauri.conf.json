{
  "$schema": "https://raw.githubusercontent.com/nicepkg/vscode-tauri/main/schemas/tauri.conf.schema.json",
  "productName": "OpenLocalRouter",
  "version": "0.1.0",
  "identifier": "com.openlocalrouter.app",
  "build": {
    "frontendDist": "../frontend/dist",
    "devUrl": "http://localhost:19528",
    "beforeDevCommand": "",
    "beforeBuildCommand": ""
  },
  "app": {
    "windows": [],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
